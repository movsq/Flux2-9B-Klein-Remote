# ─────────────────────────────────────────────────────────────────────────────
# Flux2-9B-Klein-Remote — Central Configuration
# Copy this to .env and fill in your values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Deployment target ─────────────────────────────────────────────────────────
# "local"  → server runs on localhost:PORT (Vite proxy + pc-client both use localhost)
# "remote" → server runs on FLUX_KLEIN_HOST (pc-client builds wss://FLUX_KLEIN_HOST URL)
DEPLOY_MODE=local

# ── PC secret ─────────────────────────────────────────────────────────────────
# Shared secret for PC WebSocket auth. Use a long random string in production.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PC_SECRET=

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create a project at https://console.cloud.google.com
# → APIs & Services → Credentials → OAuth 2.0 Client ID (Web application)
# Authorized JS origins: https://YOUR_DOMAIN (or http://localhost:5173 for dev)
# Authorized redirect URIs: (none needed — using Google ID token flow)
GOOGLE_CLIENT_ID=
# Vite needs the VITE_ prefix to expose env vars to the browser client.
# Set this to the SAME value as GOOGLE_CLIENT_ID.
VITE_GOOGLE_CLIENT_ID=

# ── JWT ───────────────────────────────────────────────────────────────────────
# Random secret for signing session JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# ── Server ────────────────────────────────────────────────────────────────────
# Port the Node.js relay listens on (used by local dev and Docker internally).
PORT=3000
# Session tokens expire after this many milliseconds (default: 24 hours).
SESSION_TTL_MS=86400000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Required in production.
# Example: https://flux2-klein.example.com
# Leave blank for local dev only (allows all origins).
ALLOWED_ORIGINS=

# ── Reverse proxy ─────────────────────────────────────────────────────────────
# Set to "true" when the server runs behind Caddy/nginx so rate limiting uses
# X-Forwarded-For. Leave "false" when the server is directly exposed.
BEHIND_PROXY=false

# ── Storage limits ────────────────────────────────────────────────────────────
# Maximum stored results (encrypted images) per user. Prevents disk exhaustion.
MAX_RESULTS_PER_USER=500

# Maximum total active jobs across all users. Prevents identity-farming floods
# from different code tokens filling the queue beyond what the GPU can drain.
MAX_TOTAL_QUEUE_DEPTH=50

# ── Access code login ─────────────────────────────────────────────────────────
# Set to "false" to disable access-code login entirely.
# Existing codes are preserved in the database but cannot be used to authenticate.
# The "Enter access code" button disappears from the login page and the admin
# code-generation controls are greyed out with a warning.
# Set back to "true" (or remove the line) to re-enable without any DB changes.
ACCESS_CODES_ENABLED=true

# ── Invite requirement ────────────────────────────────────────────────────────
# Controls whether a valid invite code is required to register a new account
# (applies to both Google OAuth and e-mail/password registration).
# Defaults to "true" when unset — invite codes required by default.
# Set to "false" to allow open registration.
INVITE_REQUIRED=true

# ── Remote host ───────────────────────────────────────────────────────────────
# Hostname serving the app in remote mode.
# Examples:
#   Tailscale MagicDNS:  flux2-klein.tailXXXXX.ts.net
#   Custom domain:       flux2-klein.example.com
# Use a real hostname, not a raw LAN IP, so browsers get a valid secure context.
# For `.ts.net` hosts, Caddy can use either Tailscale HTTPS Certificates (preferred)
# or the self-signed `tls internal` fallback if you explicitly enable it.
FLUX_KLEIN_HOST=

# ── TLS verification (pc-client) ──────────────────────────────────────────────
# Set to "true" to skip SSL certificate verification.
# Use this ONLY for Tailscale self-signed certs on private networks.
# Leave "false" for public domains with proper Let's Encrypt certs.
SKIP_TLS_VERIFY=false

# Optional SHA-256 hex digest of the PC public key (printed by keygen.py).
# When set, the server rejects `/ws/pc` pubkey messages that do not match.
PC_PUBLIC_KEY_FINGERPRINT=

# ── ComfyUI (pc-client) ───────────────────────────────────────────────────────
# URL of the local ComfyUI instance running on your PC.
COMFYUI_URL=http://127.0.0.1:8188

# ── PC keypair paths ──────────────────────────────────────────────────────────
# Generated once by: cd pc-client && python keygen.py
# Back up private_key.pem somewhere safe — losing it breaks encryption.
# If you launch from the repo root, setting these to pc-client/... is safest.
PRIVATE_KEY_PATH=private_key.pem
PUBLIC_KEY_PATH=public_key.pem

# ── Reconnect ─────────────────────────────────────────────────────────────────
RECONNECT_DELAY=5

# ── Optional: override built frontend path (server static-file serving) ─────
# Defaults to <repo-root>/client/dist relative to the server binary.
# Set this if you build the frontend to a custom location.
# CLIENT_DIST_PATH=

# ─────────────────────────────────────────────────────────────────────────────
# VPS / Manual deployment (only needed if NOT using GitHub Actions).
# If using GitHub Actions, set these as repository secrets instead.
# ─────────────────────────────────────────────────────────────────────────────
VPS_USER=root
# SSH-reachable address of your VPS (public IP, hostname, or Tailscale IP).
VPS_SSH_HOST=
VPS_PATH=/root/flux2-9b-klein-remote
